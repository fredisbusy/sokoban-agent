# 이 파일을 .env로 복사하고 실행 중인 Ollama 서버와 설치된 모델을 지정합니다.
OLLAMA_API_BASE=https://model.byfred.io
OLLAMA_MODEL=qwen3.6:27b-mlx
OLLAMA_TIMEOUT_SECONDS=300
OLLAMA_TEMPERATURE=0
OLLAMA_NUM_CTX=8192
OLLAMA_MAX_OUTPUT_TOKENS=512
OLLAMA_STRATEGY_MAX_OUTPUT_TOKENS=512
OLLAMA_KEEP_ALIVE=30m
OLLAMA_THINK=false

LANGSMITH_API_KEY=lsv2_발급받은키
LANGSMITH_ENDPOINT=https://apac.api.smith.langchain.com
LANGSMITH_TRACING=true
LANGSMITH_PROJECT=sokoban-agent
